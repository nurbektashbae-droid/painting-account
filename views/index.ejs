<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Остатки на складе</title>
    <style>
<link rel="stylesheet" href="/style.css">
        @import url('https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap');
        body {
            font-family: 'Roboto', Arial, sans-serif;
            margin: 0;
            padding: 15px;
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            color: #333;
        }
        .container { max-width: 1100px; margin: 0 auto; }
        h1 { text-align: center; color: #1e3a8a; margin-bottom: 10px; }
        .subtitle { text-align: center; color: #64748b; margin-bottom: 25px; }
        
        .nav {
            display: flex; 
            flex-wrap: wrap; 
            gap: 12px; 
            justify-content: center; 
            margin: 25px 0;
        }
        .nav a {
            padding: 12px 24px;
            background: #1e40af;
            color: white;
            text-decoration: none;
            border-radius: 50px;
            font-weight: 500;
            box-shadow: 0 4px 8px rgba(0,0,0,0.15);
        }

        table {
            width: 100%;
            border-collapse: collapse;
            background: white;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 10px 15px rgba(0,0,0,0.1);
        }
        th, td {
            padding: 15px;
            text-align: left;
            border-bottom: 1px solid #e2e8f0;
        }
        th { background: #1e40af; color: white; }
        .area { color: #16a34a; font-weight: bold; font-size: 1.1em; }
    </style>
</head>
<body>
<div class="container">
    <h1>📦 Остатки на складе</h1>
    <p class="subtitle">Актуальная информация по покраске изделий</p>

    <div class="nav">
        <a href="/">🔄 Обновить страницу</a>
        <a href="/request">📝 Оставить заявку на заказ</a>
    </div>

    <table>
        <tr>
            <th>Изделие</th>
            <th>Размер</th>
            <th>Не крашенные</th>
            <th>Крашенные</th>
            <th>м² крашенных</th>
        </tr>
        <% products.forEach(p => { 
            const area = ((p.paintedStock || 0) * (p.length||0) * (p.width||0)).toFixed(1);
        %>
            <tr>
                <td><strong><%= p.name %></strong></td>
                <td><%= (p.length||0) %> × <%= (p.width||0) %> м</td>
                <td><%= p.rawStock || 0 %></td>
                <td><strong><%= p.paintedStock || 0 %></strong></td>
                <td class="area"><%= area %> м²</td>
            </tr>
        <% }); %>
    </table>

</div>
</body>
</html>
