<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Вход</title>
    <style>body{font-family:Arial;display:flex;justify-content:center;align-items:center;height:100vh;background:#f0f0f0;margin:0}.card{background:white;padding:30px;border-radius:12px;box-shadow:0 4px 15px rgba(0,0,0,0.1);width:300px;text-align:center}input,button{width:100%;padding:12px;margin:10px 0;border-radius:8px}button{background:#007bff;color:white;border:none;cursor:pointer}
<link rel="stylesheet" href="/style.css"> 
</style>
</head>
<body>
    <div class="card">
        <h2>Админ панель</h2>
        <% if (error) { %><p style="color:red"><%= error %></p><% } %>
        <form method="POST" action="/login">
            <input type="password" name="password" placeholder="Пароль" required>
            <button type="submit">Войти</button>
        </form>
        <p><a href="/">Посмотреть остатки</a></p>
    </div>
</body>
</html>
